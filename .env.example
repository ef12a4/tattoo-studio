# Production Environment Variables
# Copy this file to .env and update with your values

# Security
SECRET_KEY=your_very_secure_secret_key_here

# Database
DATABASE_URL=postgresql://postgres:your_password@postgres:5432/tattoo_studio
POSTGRES_DB=tattoo_studio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Payment Gateways
STRIPE_PUBLIC_KEY=pk_live_your_stripe_public_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
IYZICO_API_KEY=your_iyzico_api_key
IYZICO_SECRET_KEY=your_iyzico_secret_key

# Firebase
FIREBASE_CONFIG='{"apiKey":"your_firebase_api_key","authDomain":"your-project.firebaseapp.com","databaseURL":"https://your-project.firebaseio.com","projectId":"your-project","storageBucket":"your-project.appspot.com","messagingSenderId":"123456789","appId":"1:123456789:web:abcdef"}

# Domain Configuration
DOMAIN=your-domain.com
